config {
  disabled: true,
  type: "table",
  name: "gcp_product_categories",
  description: "Example of generating a customer-specific GCP product hierarchy"
}

-- Main aggregation query, TODO: simplify with a label related subquery and by pulling from the repartitioned table
WITH BillingDataWithMachineSpec AS (
  SELECT *, 
    sku.id AS sku_id,
    sku.description AS sku_description,
    service.description AS service_description,
    -- Extract machine_spec, cores, and memory
    (
      SELECT l.value
      FROM UNNEST(system_labels) AS l
      WHERE l.key = 'compute.googleapis.com/machine_spec'
      LIMIT 1
    ) AS machine_spec,
    (
      SELECT l.value
      FROM UNNEST(system_labels) AS l
      WHERE l.key = 'compute.googleapis.com/cores'
      LIMIT 1
    ) AS cores,
    (
      SELECT l.value
      FROM UNNEST(system_labels) AS l
      WHERE l.key = 'compute.googleapis.com/memory'
      LIMIT 1
    ) AS memory,
  FROM ${ref(dataform.projectConfig.vars.source_view_name)} 
  WHERE NOT REGEXP_CONTAINS(sku.description, r'Commitment') -- Build dimension on usage
),
SkuUnique AS (
  -- This CTE collapses multiple rows for the same SKU into one, preferring non-null values
  SELECT
    sku_id,
    any_value(sku_description) AS raw_sku_description,
    any_value(service_description) AS service_description,
    any_value(machine_spec) AS machine_spec,
    any_value(cores) AS cores,
    any_value(memory) AS memory
  FROM BillingDataWithMachineSpec
  GROUP BY sku_id
),
ClassifiedData AS (
  SELECT
    s.sku_id,
    s.raw_sku_description,
    s.service_description,
    s.machine_spec,
    s.cores,
    s.memory,

----------------------------------------------
-- Level 1: Custom Product Service Category

    CASE
      -- Committed Use Discounts
      WHEN lower(s.raw_sku_description) = 'committed use discount' THEN 'Commitments & Capacity' 
      -- Marketplace AI Vendors
      WHEN s.service_description = 'Marketplace' AND EXISTS(
        SELECT 1 FROM UNNEST(['Anthropic', 'OpenAI', 'Mistral', 'AI21', 'Cohere']) AS vendor
        WHERE s.raw_sku_description LIKE '%' || vendor || '%'
      ) THEN 'AI'
      -- Other Marketplace
      WHEN s.service_description = 'Marketplace' THEN 'Marketplace'

      -- Compute Engine Breakdowns
      WHEN s.service_description = 'Compute Engine' THEN
        CASE
          -- AI (GPU/TPU Compute)
          WHEN LOWER(COALESCE(s.machine_spec, '')) LIKE 'a2%' OR LOWER(COALESCE(s.machine_spec, '')) LIKE 'a3%' OR LOWER(COALESCE(s.machine_spec, '')) LIKE 'g2%'
            OR s.raw_sku_description LIKE '%GPU%' OR s.raw_sku_description LIKE '%TPU%' THEN 'AI'
          -- Block Storage
          WHEN UPPER(s.raw_sku_description) LIKE '%DISK%' OR s.raw_sku_description LIKE '%PD%' OR s.raw_sku_description LIKE '%Snapshot%' OR s.raw_sku_description LIKE '%Local SSD%' THEN 'Block Storage'
          -- Networking
          WHEN s.raw_sku_description LIKE '%Egress%' OR s.raw_sku_description LIKE '%Ingress%' OR s.raw_sku_description LIKE '%Network%' OR s.raw_sku_description LIKE '%Load Balanc%' OR s.raw_sku_description LIKE '%IP Address%' OR s.raw_sku_description LIKE '%Data Transfer%' THEN 'Networking'
          -- Compute VMs
          WHEN s.machine_spec IS NOT NULL THEN 'Compute'
          WHEN s.raw_sku_description LIKE '%Compute%' OR s.raw_sku_description LIKE '%Vmimage%' OR s.raw_sku_description LIKE '%Instance%' OR s.raw_sku_description LIKE '%Sole Tenancy%' OR s.raw_sku_description LIKE '%Reservation%' OR s.raw_sku_description LIKE '%VM Manager%' THEN 'Compute'
          ELSE 'Others'
        END

      -- Networking from other services
      WHEN s.service_description IN ('Cloud SQL') AND (s.raw_sku_description LIKE '%Network%') THEN 'Networking'

      -- Service-based classifications
      WHEN s.service_description IN ('AI Platform', 'Vertex AI', 'AutoML', 'Speech-to-Text', 'Text-to-Speech', 'Natural Language API', 'Translation API', 'Dialogflow API', 'Gemini API', 'Deep Learning VM', 'Notebooks') THEN 'AI'
      WHEN s.service_description IN ('Kubernetes Engine', 'Cloud Functions', 'Cloud Run', 'App Engine','Firebase Hosting','Firebase App Hosting','Cloud Build','Cloud Run Functions','Cloud Scheduler') THEN 'Serverless'
      WHEN s.service_description IN ('Cloud Storage', 'Filestore', 'Cloud Filestore') THEN 'Storage'
      WHEN s.service_description IN ('Cloud SQL', 'Cloud Bigtable', 'Cloud Spanner', 'AlloyDB', 'Cloud Memorystore', 'Firestore', 'Datastore', 'Bigtable') or s.service_description like '%BigQuery%' THEN 'Databases'
      WHEN s.service_description IN ('Cloud Key Management Service (KMS)','Security Command Center', 'Cloud Key Management Service', 'Secret Manager', 'Google Cloud Armor', 'Identity Platform', 'Certificate Authority Service', 'Certificate Manager') THEN 'Security'
      WHEN s.service_description IN ('Networking', 'Virtual Private Cloud', 'Cloud DNS', 'Cloud Load Balancing', 'Cloud CDN', 'Cloud Interconnect', 'Cloud VPN', 'NAT Service', 'Network Connectivity Center') OR s.raw_sku_description LIKE '%Data Transfer%' OR s.raw_sku_description LIKE '%Static Ip%' OR s.raw_sku_description LIKE '%Cloud Interconnect%' OR s.raw_sku_description LIKE '%External IP%' THEN 'Networking'

      -- 'Others'
      WHEN s.service_description IN (
        'Dataflow', 'Dataproc', 
        'Cloud Logging', 'Cloud Monitoring', 'Cloud Build', 'Composer', 'Data Fusion'
      ) THEN 'Others'

      ELSE 'Others'
    END AS custom_product_category
FROM SkuUnique s
)
SELECT
-----------------------------------------------------------------------------
-- DEBUGGING: SKU description, Service and/or machine details for review of logic
--   cd.raw_sku_description,
--   cd.service_description,
--   cd.machine_spec,
--   cd.cores,
--   cd.memory,
-----------------------------------------------------------------------------
  --cd.sku_id,
  cd.custom_product_category,

----------------------------------------------
-- Level 2: Custom Service Descriptions

  CASE cd.custom_product_category

    WHEN 'Commitments & Capacity' THEN 
        CASE
          WHEN LOWER(cd.raw_sku_description) LIKE '%compute flexible%' THEN 'Compute Flexible'
          ELSE ''
        END 

    WHEN 'Compute' THEN
      CASE
        WHEN cd.machine_spec IS NULL THEN 
          CASE WHEN cd.raw_sku_description LIKE '%N2%' or cd.raw_sku_description LIKE 'Custom%' or cd.raw_sku_description LIKE '%N1%' THEN 'General Purpose'
          END
        WHEN STARTS_WITH(LOWER(cd.machine_spec), 'c') THEN 'CPU Optimized'
        WHEN STARTS_WITH(LOWER(cd.machine_spec), 'm') THEN 'Memory Optimized'
        ELSE 'General Purpose'
      END

    WHEN 'AI' THEN
      CASE
        WHEN EXISTS(
          SELECT 1 FROM UNNEST(['Anthropic', 'OpenAI', 'Mistral', 'AI21', 'Cohere']) AS vendor
          WHERE cd.raw_sku_description LIKE '%' || vendor || '%'
        ) THEN COALESCE(REGEXP_EXTRACT(cd.raw_sku_description, r'(Anthropic|OpenAI|Mistral|AI21|Cohere)'), 'AI Vendor')
        WHEN cd.service_description = 'Compute Engine' THEN 'GPU Compute'
        WHEN cd.service_description = 'Workbench' THEN 'Workbench'
        ELSE cd.service_description
      END

    WHEN 'Storage' THEN cd.service_description
    WHEN 'Databases' THEN cd.service_description
    WHEN 'Networking' THEN
        CASE
            WHEN cd.raw_sku_description LIKE '%Interconnect%' THEN 'Interconnect'
            WHEN cd.raw_sku_description LIKE '%Egress%' OR cd.raw_sku_description LIKE '%Ingress%' OR cd.raw_sku_description LIKE '%Data Transfer%' THEN 'Data Transfer'
            WHEN cd.raw_sku_description LIKE '%Load Balancing%' OR cd.raw_sku_description LIKE '%Load Balance%' THEN 'Load Balancing'
            WHEN cd.raw_sku_description LIKE '%VPN%' THEN 'VPN'
            WHEN cd.raw_sku_description LIKE '%NAT%' THEN 'NAT'
            ELSE cd.service_description
        END
    WHEN 'Block Storage' THEN
        CASE
          WHEN LOWER(cd.raw_sku_description) LIKE '%snapshot%' THEN 'Snapshots'
          WHEN cd.raw_sku_description LIKE '%SSD%' THEN 'SSD-based storage'
          ELSE 'Standard Storage'
        END 
    ELSE cd.service_description
  END AS custom_service_description,

----------------------------------------------
-- Level 3: Custom Sub-categories

  CASE cd.custom_product_category
     --TODO: calculate LLM or AI type from sku desc
    -- WHEN 'AI' THEN
    -- CASE
    --     WHEN LOWER(cd.custom_service_description) LIKE 'vertex%' THEN 'XYZ'
    --     ELSE ''
    -- END 
    WHEN 'Commitments & Capacity' THEN
      CASE
        WHEN cd.machine_spec IS NULL THEN ''
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%d' THEN 'AMD'
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%x' THEN 'Arm'
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%a' THEN 'Arm'
        ELSE 'Intel'
      END
    WHEN 'Compute' THEN -- Processor Type
      CASE
        WHEN cd.machine_spec IS NULL THEN 
          CASE WHEN cd.raw_sku_description LIKE '%N2%' or cd.raw_sku_description LIKE '%N1%' THEN 'Intel'
          END
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%d' THEN 'AMD'
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%x' THEN 'Arm'
        WHEN LOWER(SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) LIKE '%a' THEN 'Arm'
        ELSE 'Intel'
      END
    WHEN 'Storage' THEN
        CASE
            WHEN cd.raw_sku_description LIKE '%Storage%' THEN 'Storage'
            WHEN cd.raw_sku_description LIKE '%Egress%' OR cd.raw_sku_description LIKE '%Data Transfer%' THEN 'Data Transfer'
            WHEN UPPER(cd.raw_sku_description) LIKE UPPER('%class a%')THEN 'Class A Operations' 
            WHEN UPPER(cd.raw_sku_description) LIKE UPPER('%class b%')THEN 'Class B Operations' 
            WHEN cd.raw_sku_description LIKE '%Ops%' OR cd.raw_sku_description LIKE '%Request%' THEN 'Operations'
            ELSE ''
        END
    WHEN 'Databases' THEN
      CASE
        WHEN cd.raw_sku_description LIKE '%PostgreSQL%' THEN 'PostgreSQL'
        WHEN cd.raw_sku_description LIKE '%MySQL%' THEN 'MySQL'
        WHEN cd.raw_sku_description LIKE '%SQL Server%' THEN 'SQL Server'
        WHEN LOWER(cd.raw_sku_description) LIKE '%redis%' THEN 'Redis'
        WHEN LOWER(cd.raw_sku_description) LIKE '%memcached%' THEN 'Memcached'
        WHEN cd.service_description = 'Cloud Bigtable' THEN 'Bigtable'
        WHEN cd.service_description = 'Cloud Spanner' THEN 'Spanner'
        WHEN cd.service_description = 'Firestore' THEN 'Firestore'
        WHEN cd.service_description = 'Datastore' THEN 'Datastore'
        ELSE ''
      END
    WHEN 'Networking' THEN
      CASE
        WHEN cd.raw_sku_description LIKE '%Transfer Out%' THEN 'Egress'
        WHEN cd.raw_sku_description LIKE '%Transfer In%' THEN 'Ingress'
        WHEN cd.raw_sku_description LIKE '%Inter Region%' THEN 'Inter-Region'
        ELSE ''
      END
    WHEN 'Block Storage' THEN
      CASE
          WHEN cd.raw_sku_description LIKE '%Balanced PD%' or cd.raw_sku_description LIKE '%Hyperdisk Balanced%' THEN 'Balanced'
          WHEN lower(cd.raw_sku_description) LIKE '%extreme%' THEN 'Extreme'
          WHEN lower(cd.raw_sku_description) LIKE '%standard%' OR cd.raw_sku_description LIKE '%PD Capacity%' THEN 'Standard'
          WHEN lower(cd.raw_sku_description) LIKE '%ssd%' THEN 'Local SSD'
          WHEN cd.raw_sku_description LIKE '%Hyperdisk%' THEN 'High-performance'
          ELSE ''
      END
    WHEN 'Serverless' THEN 
        CASE
            WHEN lower(cd.raw_sku_description) LIKE '%autopilot%' and cd.service_description = 'Kubernetes Engine' then 'Autopilot'
            WHEN lower(cd.raw_sku_description) LIKE '%regional%' and cd.service_description = 'Kubernetes Engine' then 'Regional'
            WHEN lower(cd.raw_sku_description) LIKE '%storage%' and cd.service_description = 'App Engine' then 'Storage'
            ELSE ''
        END
    ELSE ''
  END AS service_lvl_lvl3,

-------------------------------
-- lvl 4
  CASE cd.custom_product_category
    WHEN 'Compute' THEN
      CASE
        WHEN cd.machine_spec IS NULL THEN 
          CASE WHEN cd.raw_sku_description LIKE '%N2%' THEN 'n2'
               WHEN cd.raw_sku_description LIKE '%N1%' THEN 'n1'
          END
        WHEN (SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) = 'custom' THEN 'n1'
        ELSE SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]
        END
    WHEN 'AI' THEN
      CASE
        WHEN LOWER(cd.raw_sku_description) LIKE '%text%' THEN 'Text'
        WHEN LOWER(cd.raw_sku_description) LIKE '%image%' THEN 'Images'
        WHEN LOWER(cd.raw_sku_description) LIKE '%video%' THEN 'Video'
        WHEN LOWER(cd.raw_sku_description) LIKE '%audio%' THEN 'Audio'
        WHEN cd.machine_spec IS NOT NULL THEN
          CASE
            WHEN (SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) = 'custom' THEN 'n1'
            ELSE SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]
            END 
        ELSE ''
      END
      
    WHEN 'Storage' THEN
        CASE
            WHEN cd.raw_sku_description LIKE '%Standard%' OR cd.raw_sku_description LIKE '%Regional%' OR cd.raw_sku_description LIKE '%Multi-Regional%' THEN 'Hot'
            WHEN cd.raw_sku_description LIKE '%Nearline%' THEN 'Warm'
            WHEN cd.raw_sku_description LIKE '%Coldline%' THEN 'Cold'
            WHEN cd.raw_sku_description LIKE '%Archive%' THEN 'Cold'
            ELSE ''
        END
    WHEN 'Databases' THEN ''
    WHEN 'Block Storage' THEN
      CASE
          WHEN cd.raw_sku_description LIKE '%Capacity%' THEN 'Capacity'
          WHEN cd.raw_sku_description LIKE '%Throughput%' THEN 'Throughput'
          WHEN cd.raw_sku_description LIKE '%IOPS%' THEN 'IOPS'
          WHEN cd.raw_sku_description LIKE '%Hyperdisk%' THEN 'High-performance'
          ELSE ''
        END
   WHEN 'Serverless' THEN 
        CASE
            WHEN lower(cd.raw_sku_description) LIKE '%cpu%' THEN 'Pods'
            WHEN lower(cd.raw_sku_description) LIKE '%memory%' THEN 'Clusters'
            ELSE ''
        END
    ELSE ''
  END AS service_lvl_lvl4,

-------------------------------
-- lvl 5
  CASE cd.custom_product_category
   WHEN 'AI' THEN
      CASE
        WHEN LOWER(cd.raw_sku_description) LIKE '%input%' THEN 'Input'
        WHEN LOWER(cd.raw_sku_description) LIKE '%output%' THEN 'Output'
        WHEN LOWER(cd.raw_sku_description) LIKE '%pipeline%' OR LOWER(cd.raw_sku_description) LIKE '%training%' THEN 'Pipeline'
        WHEN cd.machine_spec IS NOT NULL THEN
            CASE 
              WHEN (SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) = 'custom' THEN 'custom'
              ELSE SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(1)]
            END 
        ELSE ''
      END
   
    WHEN 'Compute' THEN
      CASE 
        WHEN cd.machine_spec IS NULL THEN 'standard'
        WHEN (SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(0)]) = 'custom' THEN 'custom'
        ELSE SPLIT(cd.machine_spec, '-')[SAFE_OFFSET(1)]
      END
    WHEN 'Storage' THEN
        CASE
          WHEN cd.raw_sku_description LIKE '%Standard%' THEN 'Standard'
          WHEN cd.raw_sku_description LIKE '%Nearline%' THEN 'Nearline'
          WHEN cd.raw_sku_description LIKE '%Coldline%' THEN 'Coldline'
          WHEN cd.raw_sku_description LIKE '%Archive%' THEN 'Archive'
          ELSE ''
        END
    WHEN 'Databases' THEN ''
    WHEN 'Serverless' THEN 
        CASE
            WHEN lower(cd.raw_sku_description) LIKE '%cpu%' THEN 'CPU'
            WHEN lower(cd.raw_sku_description) LIKE '%memory%' THEN 'Memory'
            WHEN lower(cd.raw_sku_description) LIKE '%storage%' THEN 'Storage'
            ELSE ''
        END
    ELSE ''
  END AS service_lvl_lvl5,

FROM ClassifiedData cd
ORDER BY custom_service_description DESC